{
   // Use IntelliSense to find out which attributes exist for C# debugging
   // Use hover for the description of the existing attributes
   // For further information visit https://github.com/OmniSharp/omnisharp-vscode/blob/master/debugger-launchjson.md
   "version": "0.2.0",
   "configurations": [      
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            // If you have changed target frameworks, make sure to update the program path.
            "program": "${workspaceRoot}/homereadinglibraryweb/bin/Debug/net10.0/homereadinglibraryweb.dll",
            "args": [],
            "cwd": "${workspaceRoot}/homereadinglibraryweb",
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "launchBrowser": {
                "enabled": true,
                "args": "${auto-detect-url}",
                "windows": {
                    "command": "cmd.exe",
                    "args": "/C start ${auto-detect-url}"
                },
                "osx": {
                    "command": "open"
                },
                "linux": {
                    "command": "xdg-open"
                }
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
            },
            "sourceFileMap": {
                "/Views": "${workspaceRoot}/Views"
            }
        },
        {
            "name": ".NET Core Launch (web, no browser)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceRoot}/homereadinglibraryweb/bin/Debug/net10.0/homereadinglibraryweb.dll",
            "args": [],
            "cwd": "${workspaceRoot}/homereadinglibraryweb",
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "launchBrowser": {
                "enabled": false
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
            },
            "sourceFileMap": {
                "/Views": "${workspaceRoot}/Views"
            }
        },
        {
            "name": "Playwright: Admin Auth Debug",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceRoot}/homereadinglibraryweb/clientapp",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "e2e",
                "--",
                "--project=chromium-authenticated",
                "--headed",
                "--workers=1"
            ],
            "env": {
                "BAGGY_E2E_ROLE": "admin",
                "BAGGY_E2E_USE_LOCAL_STACK": "false",
                "BAGGY_E2E_BASE_URL": "https://localhost:5001",
                "BAGGY_E2E_USERNAME": "${input:baggyAdminUsername}",
                "BAGGY_E2E_PASSWORD": "${input:baggyAdminPassword}",
                "PWDEBUG": "1"
            },
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ],
    "compounds": [
        {
            "name": "Debug Admin Login (.NET + Playwright)",
            "configurations": [
                ".NET Core Launch (web, no browser)",
                "Playwright: Admin Auth Debug"
            ],
            "stopAll": true
        }
    ],
    "inputs": [
        {
            "id": "baggyAdminUsername",
            "type": "promptString",
            "description": "Baggy admin username",
            "default": "aliciapreece"
        },
        {
            "id": "baggyAdminPassword",
            "type": "promptString",
            "description": "Baggy admin password",
            "password": true
        }
    ]
}